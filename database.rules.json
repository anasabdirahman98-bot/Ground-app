{
  "rules": {
    ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
    ".write": false,

    "config": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'gerant'"
    },

    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
      "$uid": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'gerant'"
      }
    },

    "clients": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
      "$clientId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true"
      }
    },

    "reservations": {
      "$date": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
        "$resaId": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true && newData.exists()",
          ".validate": "newData.hasChildren(['terrainId','creneau','clientId','montant','statut','statutPaiement','employeId','employeNom','createdAt'])",
          "employeId": {
            ".validate": "(!data.exists() && newData.val() === auth.uid) || (data.exists() && newData.val() === data.val())"
          },
          "createdAt": {
            ".validate": "!data.exists() || newData.val() === data.val()"
          }
        }
      }
    },

    "slots": {
      "$date": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
        "$slot": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true && (!data.exists() || !newData.exists())"
        }
      }
    },

    "paiements": {
      "$date": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
        "$paiementId": {
          ".write": "auth != null && !data.exists() && newData.child('employeId').val() === auth.uid",
          ".validate": "newData.hasChildren(['resaId','montant','mode','type','employeId','employeNom','timestamp']) && newData.child('montant').isNumber() && newData.child('montant').val() > 0"
        }
      }
    },

    "clotures": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
      "$date": {
        ".write": "auth != null && !data.exists() && newData.child('employeId').val() === auth.uid",
        ".validate": "newData.hasChildren(['theoriqueEspeces','compteEspeces','ecart','employeId','employeNom','timestamp'])"
      }
    },

    "evenements": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
      "$evtId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true && (newData.exists() || root.child('users').child(auth.uid).child('role').val() === 'gerant')"
      }
    },

    "recurrences": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
      "$recId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true && (newData.exists() || root.child('users').child(auth.uid).child('role').val() === 'gerant')"
      }
    },

    "waitlist": {
      "$date": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
        "$slot": {
          "$id": {
            ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true",
            ".validate": "newData.hasChildren(['nom','employeId','createdAt'])"
          }
        }
      }
    },

    "journal": {
      "$date": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'gerant'",
        "$logId": {
          ".write": "auth != null && !data.exists() && newData.child('userId').val() === auth.uid"
        }
      }
    },

    "joueurs": {
      "$uid": {
        "public": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['nom','createdAt'])"
        },
        "prive": {
          ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('actif').val() === true)",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "equipes": {
      ".read": "auth != null",
      "$equipeId": {
        ".write": "auth != null && (!data.exists() || root.child('equipes').child($equipeId).child('capitaineId').val() === auth.uid || root.child('users').child(auth.uid).child('actif').val() === true)",
        ".validate": "newData.hasChildren(['nom','capitaineId','createdAt'])",
        "membres": {
          "$muid": {
            ".write": "auth != null && (auth.uid === $muid || root.child('equipes').child($equipeId).child('capitaineId').val() === auth.uid || root.child('users').child(auth.uid).child('actif').val() === true)"
          }
        }
      }
    },

    "matchsOuverts": {
      ".read": "auth != null",
      "$matchId": {
        ".write": "auth != null && (!data.exists() || root.child('users').child(auth.uid).child('actif').val() === true || root.child('matchsOuverts').child($matchId).child('createdBy').val() === auth.uid)",
        ".validate": "newData.hasChildren(['sport','placesTotal','statut','createdAt'])",
        "statut": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('actif').val() === true || root.child('matchsOuverts').child($matchId).child('createdBy').val() === auth.uid)"
        },
        "participants": {
          "$puid": {
            ".write": "auth != null && (auth.uid === $puid || root.child('users').child(auth.uid).child('actif').val() === true)",
            "telephone": {
              ".read": "auth != null && root.child('matchsOuverts').child($matchId).child('statut').val() === 'confirme' && root.child('matchsOuverts').child($matchId).child('participants').child(auth.uid).child('statut').val() === 'confirme'",
              ".write": "auth != null && root.child('users').child(auth.uid).child('actif').val() === true"
            }
          }
        }
      }
    }
  }
}
